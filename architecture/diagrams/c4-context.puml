@startuml c4-context

' C4-PlantUML include
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(user, "User", "Provides commands and reads rover state")

System(system, "Mars Rover Simulator", "Simulates rover movement on a grid with obstacles")

System_Ext(cli, "CLI / Interface", "Command-line or test interface")

Rel(user, cli, "Inputs commands")
Rel(cli, system, "Sends commands to rover")
Rel(system, cli, "Returns final position and status")
Rel(cli, user, "Displays results")

@enduml
